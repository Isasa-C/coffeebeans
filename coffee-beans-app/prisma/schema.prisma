generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CoffeeBean {
  id        String   @id @default(cuid())
  brand     String
  price     Float
  quantity  Int
  weight    Int      @default(250)
  rating    Float
  bestFor   String
  comments  String?
  imageUrl  String
  imageFit  String   @default("contain")
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
