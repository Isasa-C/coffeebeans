generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CoffeeBean {
  id        String   @id @default(cuid())
  brand     String
  location  String
  price     Float
  quantity  Int
  rating    Float
  bestFor   String
  comments  String?
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
